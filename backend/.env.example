# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/spotify_reviews
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/spotify_reviews

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o

# Reddit (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=SpotifyReviewScraper/1.0

# App
APP_ENV=development
LOG_LEVEL=INFO

# RAG settings
RAG_TOP_K=10
RAG_MIN_SIMILARITY=0.70
